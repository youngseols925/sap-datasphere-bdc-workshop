{
  "definitions": {
    "WS_HL_SQLV_OPEN_ORDER_CDSV": {
      "kind": "entity",
      "@EndUserText.label": "[워크샵] Open Order CDS View SQL View",
      "@ObjectModel.supportedCapabilities": [
        {
          "#": "DATA_STRUCTURE"
        }
      ],
      "elements": {
        "SalesDocument": {
          "@EndUserText.label": "영업전표번호",
          "type": "cds.String",
          "length": 10
        },
        "CreationDate": {
          "@EndUserText.label": "생성일",
          "type": "cds.Date"
        },
        "CalendarYearMonth": {
          "@EndUserText.label": "생성년월",
          "type": "cds.String",
          "length": 6
        },
        "RequestedDeliveryDate": {
          "@EndUserText.label": "납품요청일",
          "type": "cds.Date"
        },
        "SalesOrganization": {
          "@EndUserText.label": "판매조직",
          "type": "cds.String",
          "length": 4
        },
        "BillingCompanyCode": {
          "@EndUserText.label": "회사코드",
          "type": "cds.String",
          "length": 4
        },
        "DistributionChannel": {
          "@EndUserText.label": "유통채널",
          "type": "cds.String",
          "length": 2
        },
        "SalesDocumentType": {
          "@EndUserText.label": "판매전표유형",
          "type": "cds.String",
          "length": 4
        },
        "SoldToParty": {
          "@EndUserText.label": "주문자(Sold-to)",
          "type": "cds.String",
          "length": 10
        },
        "SalesOffice": {
          "@EndUserText.label": "판매사무소",
          "type": "cds.String",
          "length": 4
        },
        "SalesGroup": {
          "@EndUserText.label": "판매그룹",
          "type": "cds.String",
          "length": 3
        },
        "TransactionCurrency": {
          "@EndUserText.label": "전표통화",
          "type": "cds.String",
          "length": 5
        },
        "SalesOrganizationCurrency": {
          "@EndUserText.label": "현지통화",
          "type": "cds.String",
          "length": 5
        },
        "SDDocumentCategory": {
          "@EndUserText.label": "영업전표범주",
          "type": "cds.String",
          "length": 4
        },
        "SalesDocumentItem": {
          "@EndUserText.label": "항목번호",
          "type": "cds.String",
          "length": 6
        },
        "Material": {
          "@EndUserText.label": "자재번호",
          "type": "cds.String",
          "length": 40,
          "@ObjectModel.foreignKey.association": {
            "=": "_SAP_LO_Pr"
          }
        },
        "MaterialGroup": {
          "@EndUserText.label": "자재그룹",
          "type": "cds.String",
          "length": 9
        },
        "Division": {
          "@EndUserText.label": "제품군",
          "type": "cds.String",
          "length": 2
        },
        "Plant": {
          "@EndUserText.label": "플랜트",
          "type": "cds.String",
          "length": 4
        },
        "OrderQuantityUnit": {
          "@EndUserText.label": "판매단위",
          "type": "cds.String",
          "length": 3
        },
        "SalesDocumentItemCategory": {
          "@EndUserText.label": "항목범주",
          "type": "cds.String",
          "length": 4
        },
        "SalesDocumentRjcnReason": {
          "@EndUserText.label": "거부사유",
          "type": "cds.String",
          "length": 2
        },
        "SalesDistrict": {
          "@EndUserText.label": "판매지역",
          "type": "cds.String",
          "length": 6
        },
        "OrderQuantity": {
          "@EndUserText.label": "주문수량",
          "precision": 13,
          "scale": 3,
          "type": "cds.Decimal",
          "@AnalyticsDetails.measureType": {
            "#": "BASE"
          },
          "@Aggregation.default": {
            "#": "SUM"
          }
        },
        "CONFIRMED_QTY": {
          "@EndUserText.label": "확정수량",
          "precision": 13,
          "scale": 3,
          "type": "cds.Decimal",
          "@AnalyticsDetails.measureType": {
            "#": "BASE"
          },
          "@Aggregation.default": {
            "#": "SUM"
          }
        },
        "GI_QTY": {
          "@EndUserText.label": "출고수량",
          "precision": 13,
          "scale": 3,
          "type": "cds.Decimal",
          "@AnalyticsDetails.measureType": {
            "#": "BASE"
          },
          "@Aggregation.default": {
            "#": "SUM"
          }
        },
        "GI_DATE": {
          "isCalculated": true,
          "@EndUserText.label": "출고일자",
          "type": "cds.Date"
        },
        "BILL_QTY": {
          "@EndUserText.label": "청구수량",
          "precision": 13,
          "scale": 3,
          "type": "cds.Decimal",
          "@AnalyticsDetails.measureType": {
            "#": "BASE"
          },
          "@Aggregation.default": {
            "#": "SUM"
          }
        },
        "BILL_AMT": {
          "@EndUserText.label": "청구금액",
          "precision": 13,
          "scale": 3,
          "type": "cds.Decimal",
          "@AnalyticsDetails.measureType": {
            "#": "BASE"
          },
          "@Aggregation.default": {
            "#": "SUM"
          }
        },
        "OPEN_DLV_QTY": {
          "@EndUserText.label": "미납품수량",
          "precision": 13,
          "scale": 3,
          "type": "cds.Decimal",
          "@AnalyticsDetails.measureType": {
            "#": "BASE"
          },
          "@Aggregation.default": {
            "#": "SUM"
          }
        },
        "UNBILLED_QTY": {
          "@EndUserText.label": "미청구수량",
          "precision": 13,
          "scale": 3,
          "type": "cds.Decimal",
          "@AnalyticsDetails.measureType": {
            "#": "BASE"
          },
          "@Aggregation.default": {
            "#": "SUM"
          }
        },
        "DELIVERY_STATUS": {
          "@EndUserText.label": "납품진행상태",
          "type": "cds.String",
          "length": 11
        },
        "COMPARISON_DATE": {
          "@EndUserText.label": "비교기준일",
          "type": "cds.Date"
        },
        "RDD_LEADTIME_DAYS": {
          "@EndUserText.label": "납품요청일 리드타임(일)",
          "type": "cds.Integer"
        },
        "RDD_COMPLIANCE": {
          "@EndUserText.label": "납품요청일 준수여부",
          "type": "cds.String",
          "length": 7
        },
        "_SAP_LO_Pr": {
          "type": "cds.Association",
          "@EndUserText.label": "WS_HL_SQLV_OPEN_ORDER_CDSV to SAP_LO_Product_V2",
          "on": [
            {
              "ref": [
                "Material"
              ]
            },
            "=",
            {
              "ref": [
                "_SAP_LO_Pr",
                "Product"
              ]
            }
          ],
          "target": "SAP_LO_Product_V2"
        }
      },
      "query": {
        "SELECT": {
          "from": {
            "join": "left",
            "args": [
              {
                "join": "left",
                "args": [
                  {
                    "join": "left",
                    "args": [
                      {
                        "ref": [
                          "SAP_SD_IL_C_SALESDOCUMENTITEMDEX_1"
                        ],
                        "as": "I"
                      },
                      {
                        "SELECT": {
                          "from": {
                            "ref": [
                              "SAP_SD_IL_C_SALESDOCUMENTSCHEDLINEDEX_1"
                            ]
                          },
                          "columns": [
                            {
                              "ref": [
                                "SalesDocument"
                              ]
                            },
                            {
                              "ref": [
                                "SalesDocumentItem"
                              ]
                            },
                            {
                              "func": "SUM",
                              "args": [
                                {
                                  "ref": [
                                    "ConfdOrderQtyByMatlAvailCheck"
                                  ]
                                }
                              ],
                              "as": "CONFIRMED_QTY"
                            }
                          ],
                          "groupBy": [
                            {
                              "ref": [
                                "SalesDocument"
                              ]
                            },
                            {
                              "ref": [
                                "SalesDocumentItem"
                              ]
                            }
                          ],
                          "where": [
                            {
                              "ref": [
                                "IsConfirmedDelivSchedLine"
                              ]
                            },
                            "=",
                            {
                              "val": "X"
                            }
                          ]
                        },
                        "as": "C"
                      }
                    ],
                    "on": [
                      {
                        "ref": [
                          "I",
                          "SalesDocument"
                        ]
                      },
                      "=",
                      {
                        "ref": [
                          "C",
                          "SalesDocument"
                        ]
                      },
                      "and",
                      {
                        "ref": [
                          "I",
                          "SalesDocumentItem"
                        ]
                      },
                      "=",
                      {
                        "ref": [
                          "C",
                          "SalesDocumentItem"
                        ]
                      }
                    ]
                  },
                  {
                    "SELECT": {
                      "from": {
                        "join": "inner",
                        "args": [
                          {
                            "ref": [
                              "SAP_SD_IL_I_DELIVERYDOCUMENTITEM"
                            ],
                            "as": "DI"
                          },
                          {
                            "ref": [
                              "SAP_SD_IL_I_DELIVERYDOCUMENT"
                            ],
                            "as": "DH"
                          }
                        ],
                        "on": [
                          {
                            "ref": [
                              "DI",
                              "DeliveryDocument"
                            ]
                          },
                          "=",
                          {
                            "ref": [
                              "DH",
                              "DeliveryDocument"
                            ]
                          }
                        ]
                      },
                      "columns": [
                        {
                          "ref": [
                            "DI",
                            "ReferenceSDDocument"
                          ],
                          "as": "SO_VBELN"
                        },
                        {
                          "ref": [
                            "DI",
                            "ReferenceSDDocumentItem"
                          ],
                          "as": "SO_POSNR"
                        },
                        {
                          "func": "SUM",
                          "args": [
                            {
                              "ref": [
                                "DI",
                                "ActualDeliveredQtyInBaseUnit"
                              ]
                            }
                          ],
                          "as": "GI_QTY"
                        },
                        {
                          "func": "MAX",
                          "args": [
                            {
                              "ref": [
                                "DH",
                                "ActualGoodsMovementDate"
                              ]
                            }
                          ],
                          "as": "GI_DATE"
                        }
                      ],
                      "groupBy": [
                        {
                          "ref": [
                            "DI",
                            "ReferenceSDDocument"
                          ]
                        },
                        {
                          "ref": [
                            "DI",
                            "ReferenceSDDocumentItem"
                          ]
                        }
                      ],
                      "where": [
                        {
                          "ref": [
                            "DI",
                            "ReferenceSDDocumentCategory"
                          ]
                        },
                        "=",
                        {
                          "val": "C"
                        },
                        "and",
                        {
                          "ref": [
                            "DI",
                            "GoodsMovementStatus"
                          ]
                        },
                        "=",
                        {
                          "val": "C"
                        }
                      ]
                    },
                    "as": "G"
                  }
                ],
                "on": [
                  {
                    "ref": [
                      "I",
                      "SalesDocument"
                    ]
                  },
                  "=",
                  {
                    "ref": [
                      "G",
                      "SO_VBELN"
                    ]
                  },
                  "and",
                  {
                    "ref": [
                      "I",
                      "SalesDocumentItem"
                    ]
                  },
                  "=",
                  {
                    "ref": [
                      "G",
                      "SO_POSNR"
                    ]
                  }
                ]
              },
              {
                "SELECT": {
                  "from": {
                    "ref": [
                      "SAP_SD_IL_C_BILLINGDOCITEMBASICDEX_1"
                    ]
                  },
                  "columns": [
                    {
                      "ref": [
                        "SalesDocument"
                      ],
                      "as": "SO_VBELN"
                    },
                    {
                      "ref": [
                        "SalesDocumentItem"
                      ],
                      "as": "SO_POSNR"
                    },
                    {
                      "func": "SUM",
                      "args": [
                        {
                          "xpr": [
                            "case",
                            "when",
                            {
                              "ref": [
                                "BillingDocumentCategory"
                              ]
                            },
                            "in",
                            {
                              "list": [
                                {
                                  "val": "P"
                                },
                                {
                                  "val": "O"
                                }
                              ]
                            },
                            "then",
                            {
                              "ref": [
                                "BillingQuantityInBaseUnit"
                              ]
                            },
                            "*",
                            {
                              "val": -1
                            },
                            "else",
                            {
                              "ref": [
                                "BillingQuantityInBaseUnit"
                              ]
                            },
                            "end"
                          ]
                        }
                      ],
                      "as": "BILL_QTY"
                    },
                    {
                      "func": "SUM",
                      "args": [
                        {
                          "xpr": [
                            "case",
                            "when",
                            {
                              "ref": [
                                "BillingDocumentCategory"
                              ]
                            },
                            "in",
                            {
                              "list": [
                                {
                                  "val": "P"
                                },
                                {
                                  "val": "O"
                                }
                              ]
                            },
                            "then",
                            {
                              "ref": [
                                "NetAmount"
                              ]
                            },
                            "*",
                            {
                              "val": -1
                            },
                            "else",
                            {
                              "ref": [
                                "NetAmount"
                              ]
                            },
                            "end"
                          ]
                        }
                      ],
                      "as": "BILL_AMT"
                    }
                  ],
                  "groupBy": [
                    {
                      "ref": [
                        "SalesDocument"
                      ]
                    },
                    {
                      "ref": [
                        "SalesDocumentItem"
                      ]
                    }
                  ],
                  "where": [
                    {
                      "ref": [
                        "BillingDocumentIsCancelled"
                      ]
                    },
                    "=",
                    {
                      "val": ""
                    },
                    "and",
                    {
                      "ref": [
                        "SalesSDDocumentCategory"
                      ]
                    },
                    "=",
                    {
                      "val": "C"
                    }
                  ]
                },
                "as": "B"
              }
            ],
            "on": [
              {
                "ref": [
                  "I",
                  "SalesDocument"
                ]
              },
              "=",
              {
                "ref": [
                  "B",
                  "SO_VBELN"
                ]
              },
              "and",
              {
                "ref": [
                  "I",
                  "SalesDocumentItem"
                ]
              },
              "=",
              {
                "ref": [
                  "B",
                  "SO_POSNR"
                ]
              }
            ]
          },
          "columns": [
            {
              "ref": [
                "I",
                "SalesDocument"
              ]
            },
            {
              "func": "TO_DATE",
              "args": [
                {
                  "ref": [
                    "I",
                    "SalesDocumentDate"
                  ]
                }
              ],
              "as": "CreationDate"
            },
            {
              "func": "TO_VARCHAR",
              "args": [
                {
                  "func": "TO_DATE",
                  "args": [
                    {
                      "ref": [
                        "I",
                        "SalesDocumentDate"
                      ]
                    }
                  ]
                },
                {
                  "val": "YYYYMM"
                }
              ],
              "as": "CalendarYearMonth"
            },
            {
              "func": "TO_DATE",
              "args": [
                {
                  "ref": [
                    "I",
                    "RequestedDeliveryDate"
                  ]
                }
              ],
              "as": "RequestedDeliveryDate"
            },
            {
              "ref": [
                "I",
                "SalesOrganization"
              ]
            },
            {
              "ref": [
                "I",
                "BillingCompanyCode"
              ]
            },
            {
              "ref": [
                "I",
                "DistributionChannel"
              ]
            },
            {
              "ref": [
                "I",
                "SalesDocumentType"
              ]
            },
            {
              "ref": [
                "I",
                "SoldToParty"
              ]
            },
            {
              "ref": [
                "I",
                "SalesOffice"
              ]
            },
            {
              "ref": [
                "I",
                "SalesGroup"
              ]
            },
            {
              "ref": [
                "I",
                "TransactionCurrency"
              ]
            },
            {
              "ref": [
                "I",
                "SalesOrganizationCurrency"
              ]
            },
            {
              "ref": [
                "I",
                "SDDocumentCategory"
              ]
            },
            {
              "ref": [
                "I",
                "SalesDocumentItem"
              ]
            },
            {
              "ref": [
                "I",
                "Material"
              ]
            },
            {
              "ref": [
                "I",
                "MaterialGroup"
              ]
            },
            {
              "ref": [
                "I",
                "Division"
              ]
            },
            {
              "ref": [
                "I",
                "Plant"
              ]
            },
            {
              "ref": [
                "I",
                "OrderQuantityUnit"
              ]
            },
            {
              "ref": [
                "I",
                "SalesDocumentItemCategory"
              ]
            },
            {
              "ref": [
                "I",
                "SalesDocumentRjcnReason"
              ]
            },
            {
              "ref": [
                "I",
                "SalesDistrict"
              ]
            },
            {
              "ref": [
                "I",
                "OrderQuantity"
              ]
            },
            {
              "func": "COALESCE",
              "args": [
                {
                  "ref": [
                    "C",
                    "CONFIRMED_QTY"
                  ]
                },
                {
                  "val": 0
                }
              ],
              "as": "CONFIRMED_QTY"
            },
            {
              "func": "COALESCE",
              "args": [
                {
                  "ref": [
                    "G",
                    "GI_QTY"
                  ]
                },
                {
                  "val": 0
                }
              ],
              "as": "GI_QTY"
            },
            {
              "ref": [
                "G",
                "GI_DATE"
              ]
            },
            {
              "func": "COALESCE",
              "args": [
                {
                  "ref": [
                    "B",
                    "BILL_QTY"
                  ]
                },
                {
                  "val": 0
                }
              ],
              "as": "BILL_QTY"
            },
            {
              "func": "COALESCE",
              "args": [
                {
                  "ref": [
                    "B",
                    "BILL_AMT"
                  ]
                },
                {
                  "val": 0
                }
              ],
              "as": "BILL_AMT"
            },
            {
              "xpr": [
                {
                  "ref": [
                    "I",
                    "OrderQuantity"
                  ]
                },
                "-",
                {
                  "func": "COALESCE",
                  "args": [
                    {
                      "ref": [
                        "G",
                        "GI_QTY"
                      ]
                    },
                    {
                      "val": 0
                    }
                  ]
                }
              ],
              "as": "OPEN_DLV_QTY"
            },
            {
              "xpr": [
                {
                  "func": "COALESCE",
                  "args": [
                    {
                      "ref": [
                        "G",
                        "GI_QTY"
                      ]
                    },
                    {
                      "val": 0
                    }
                  ]
                },
                "-",
                {
                  "func": "COALESCE",
                  "args": [
                    {
                      "ref": [
                        "B",
                        "BILL_QTY"
                      ]
                    },
                    {
                      "val": 0
                    }
                  ]
                }
              ],
              "as": "UNBILLED_QTY"
            },
            {
              "xpr": [
                "case",
                "when",
                {
                  "func": "COALESCE",
                  "args": [
                    {
                      "ref": [
                        "G",
                        "GI_QTY"
                      ]
                    },
                    {
                      "val": 0
                    }
                  ]
                },
                "=",
                {
                  "val": 0
                },
                "then",
                {
                  "val": "미출고"
                },
                "when",
                {
                  "func": "COALESCE",
                  "args": [
                    {
                      "ref": [
                        "G",
                        "GI_QTY"
                      ]
                    },
                    {
                      "val": 0
                    }
                  ]
                },
                "<",
                {
                  "ref": [
                    "I",
                    "OrderQuantity"
                  ]
                },
                "then",
                {
                  "val": "부분출고"
                },
                "else",
                {
                  "val": "완전출고"
                },
                "end"
              ],
              "as": "DELIVERY_STATUS"
            },
            {
              "func": "CURRENT_DATE",
              "args": [],
              "as": "COMPARISON_DATE"
            },
            {
              "xpr": [
                "case",
                "when",
                {
                  "ref": [
                    "I",
                    "RequestedDeliveryDate"
                  ]
                },
                "is",
                "null",
                "then",
                {
                  "val": null
                },
                "else",
                {
                  "func": "DAYS_BETWEEN",
                  "args": [
                    {
                      "func": "TO_DATE",
                      "args": [
                        {
                          "ref": [
                            "I",
                            "RequestedDeliveryDate"
                          ]
                        }
                      ]
                    },
                    {
                      "func": "COALESCE",
                      "args": [
                        {
                          "ref": [
                            "G",
                            "GI_DATE"
                          ]
                        },
                        {
                          "func": "CURRENT_DATE",
                          "args": []
                        }
                      ]
                    }
                  ]
                },
                "end"
              ],
              "as": "RDD_LEADTIME_DAYS"
            },
            {
              "xpr": [
                "case",
                "when",
                {
                  "ref": [
                    "G",
                    "GI_DATE"
                  ]
                },
                "is",
                "null",
                "then",
                {
                  "val": "미출고"
                },
                "when",
                {
                  "ref": [
                    "G",
                    "GI_DATE"
                  ]
                },
                "<=",
                {
                  "func": "TO_DATE",
                  "args": [
                    {
                      "ref": [
                        "I",
                        "RequestedDeliveryDate"
                      ]
                    }
                  ]
                },
                "then",
                {
                  "val": "준수"
                },
